APP_NAME=NorteX
APP_ENV=local
APP_KEY=
# Opcional: salt estável para Hashids nas URLs. Se vazio, usa um derivado de APP_KEY.
HASHIDS_SALT=
HASHIDS_MIN_LENGTH=8
APP_DEBUG=true
# URL pública da app (obrigatória para links nos e-mails: convite, redefinição de senha)
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# file = sem tabela sessions (recomendado local / XAMPP). database = após migrate e php artisan nx:ensure-sessions
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# local | s3 (Backblaze B2 compatível S3)
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# log = grava no laravel.log | array = só testes | smtp = produção (ex.: Gmail, Mailgun, servidor próprio)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Opcional: fila para envio assíncrono (configurar worker: php artisan queue:work)
# MAIL_QUEUE_CONNECTION=database

MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Exemplo SMTP (descomente e ajuste):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.seuprovedor.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@seudominio.com
# MAIL_PASSWORD=segredo
# MAIL_SCHEME=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-005
AWS_BUCKET=nortex-arquivos
AWS_ENDPOINT=https://s3.us-east-005.backblazeb2.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Criptografia dos anexos de cliente antes do envio ao S3 (32 bytes em base64:, chave própria — não use APP_KEY)
FILE_ENCRYPTION_KEY=

VITE_APP_NAME="${APP_NAME}"

# Stripe (assinatura / webhook em https://seu-dominio/stripe/webhook)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Price IDs do Dashboard (ex.: price_xxx) — STRIPE_PRICE_FULL desbloqueia o módulo financeiro
STRIPE_PRICE_FULL=
STRIPE_PRICE_BASIC=
# Links para o cliente (substituem buy.stripe.com): {APP_URL}/assinatura/basica e .../completa
